        .content-quarters { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; width: 100%; max-width: 1200px; }
        .big-number { font-size: 5.5em; font-weight: 700; line-height: 1; }
        .big-number.accent { color: #c2491d; }
        .big-number.sage { color: #3a6b5e; }
        .stat-card { background: white; padding: 20px; border-radius: 14px; box-shadow: 0 6px 25px rgba(0,0,0,0.08); text-align: center; }
        .stat-card .number { font-size: 2.4em; font-weight: 700; background: linear-gradient(135deg, #c2491d, #3a6b5e); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .stat-card .number.a { background: linear-gradient(135deg, #c2491d, #e8683a); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .stat-card .number.s { background: linear-gradient(135deg, #3a6b5e, #4d8b7a); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .stat-card .number.g { background: linear-gradient(135deg, #b8942e, #d4ad3a); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
