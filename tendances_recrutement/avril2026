        .slide-cool { background: linear-gradient(135deg, #e8f5f0 0%, #d4edda 100%); color: #2c3e50; }
        .slide-value { background: linear-gradient(135deg, #1a1a2e 0%, #3a2a1e 100%); color: white; }
        .slide-gold { background: linear-gradient(135deg, #f5f0e0 0%, #ede4c8 100%); color: #2c3e50; }
        h1 { font-size: 3.5em; font-weight: 700; margin-bottom: 20px; text-align: center; line-height: 1.15; }
        h2 { font-size: 2.4em; font-weight: 700; margin-bottom: 20px; text-align: center; }
        .subtitle { font-size: 1.25em; opacity: 0.9; text-align: center; max-width: 900px; line-height: 1.5; }
        .content-center { text-align: center; max-width: 1100px; }
        .content-split { display: grid; grid-template-columns: 1fr 1fr; gap: 35px; width: 100%; max-width: 1200px; align-items: start; }
